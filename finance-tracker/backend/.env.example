# Plaid credentials — get these from https://dashboard.plaid.com/team/keys
PLAID_CLIENT_ID=your_client_id_here
PLAID_SECRET=your_sandbox_secret_here

# One of: sandbox, development, production
# Start with 'sandbox' for free testing with fake institutions.
PLAID_ENV=sandbox

# Comma-separated Plaid products. Default covers banking + investments + liabilities.
PLAID_PRODUCTS=transactions,investments,liabilities

# Comma-separated country codes.
PLAID_COUNTRY_CODES=US

# Display name shown inside Plaid Link.
PLAID_CLIENT_NAME=Finance Tracker
